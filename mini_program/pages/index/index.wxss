/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  background-color: white;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.2);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 表单区域 */
.form-section {
  background-color: white;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
  box-sizing: border-box;
}

.input:focus {
  border-color: #1890ff;
  background-color: white;
}

.btn-analyze {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.btn-analyze.btn-disabled {
  opacity: 0.6;
  background: #ccc;
}

/* 错误提示 */
.error-section {
  margin-bottom: 30rpx;
}

.error-card {
  background-color: #fff2f0;
  border: 2rpx solid #ffccc7;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
}

.error-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.error-message {
  font-size: 28rpx;
  color: #ff4d4f;
  flex: 1;
}

/* 分析结果 */
.result-section {
  margin-bottom: 30rpx;
}

.result-card {
  background-color: white;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.result-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.result-status.success {
  background-color: #f6ffed;
  color: #52c41a;
}

.result-info {
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-download {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: white;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.4);
}

.btn-reset {
  width: 100%;
  height: 88rpx;
  background-color: #f0f0f0;
  color: #666;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

/* 帮助区域 */
.help-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.help-link {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-decoration: underline;
}

/* 底部信息 */
.footer {
  text-align: center;
  margin-top: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}